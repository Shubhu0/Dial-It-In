{
  "expo": {
    "name": "dial-it-in",
    "slug": "dial-it-in",
    "scheme": "dial-it-in",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.dialitin"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Dial It In",
      "shortName": "Dial It In",
      "description": "Track, learn, and perfect your brew",
      "themeColor": "#C68A3A",
      "backgroundColor": "#F5EDD8",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
